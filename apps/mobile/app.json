{
  "expo": {
    "name": "Nonley",
    "slug": "nonley",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nonley",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a14"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nonley.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Nonley needs microphone access for audio calls.",
        "NSCameraUsageDescription": "Nonley needs camera access for video calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a14"
      },
      "package": "com.nonley.app",
      "permissions": ["RECORD_AUDIO", "CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#818cf8"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
